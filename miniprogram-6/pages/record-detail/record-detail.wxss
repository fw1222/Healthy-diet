/* pages/record-detail/record-detail.wxss */


.container {
  padding: 20rpx;
  background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
  min-height: 100vh;
  box-sizing: border-box;
}

/* 头部信息 */
.header {
  background: white;
  border-radius: 25rpx;
  padding: 40rpx 30rpx;
  margin-bottom: 30rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-shadow: 0 8rpx 30rpx rgba(0,0,0,0.08);
}

.date-info {
  flex: 1;
}

.date {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #2c3e50;
  margin-bottom: 10rpx;
}

.week {
  display: block;
  font-size: 28rpx;
  color: #666;
}

.score-section {
  text-align: center;
}

.score-circle {
  position: relative;
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 10rpx;
}

.circle-outer {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  background: conic-gradient(#4CAF50 0%, #4CAF50 calc(var(--progress-width, 0) * 3.6deg), #f0f0f0 calc(var(--progress-width, 0) * 3.6deg), #f0f0f0 360deg);
}

.circle-inner {
  width: 100rpx;
  height: 100rpx;
  background: white;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.score-text {
  font-size: 32rpx;
  font-weight: bold;
  color: #4CAF50;
}

.score-label {
  font-size: 24rpx;
  color: #666;
}

/* 营养概览 */
.nutrition-overview {
  background: white;
  border-radius: 25rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 8rpx 30rpx rgba(0,0,0,0.08);
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #2c3e50;
  margin-bottom: 25rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.meal-count {
  font-size: 26rpx;
  color: #4CAF50;
  background: rgba(76, 175, 80, 0.1);
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
}

.nutrition-cards {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-bottom: 25rpx;
}

.nutrition-card {
  display: flex;
  align-items: center;
  padding: 25rpx;
  border-radius: 15rpx;
  border-left: 6rpx solid;
}

.nutrition-card.protein {
  background: rgba(255, 107, 107, 0.1);
  border-left-color: #FF6B6B;
}

.nutrition-card.fat {
  background: rgba(78, 205, 196, 0.1);
  border-left-color: #4ECDC4;
}

.nutrition-card.carb {
  background: rgba(150, 206, 180, 0.1);
  border-left-color: #96CEB4;
}

.nutrient-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
  width: 60rpx;
  text-align: center;
}

.nutrient-info {
  flex: 1;
}

.nutrient-value {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: #2c3e50;
  margin-bottom: 5rpx;
}

.nutrient-label {
  display: block;
  font-size: 24rpx;
  color: #666;
}

.nutrient-progress {
  text-align: right;
}

.progress-text {
  display: block;
  font-size: 24rpx;
  font-weight: 500;
  color: #2c3e50;
  margin-bottom: 8rpx;
}

.progress-bar {
  width: 120rpx;
  height: 8rpx;
  background: #f0f0f0;
  border-radius: 4rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  border-radius: 4rpx;
  transition: width 0.3s ease;
  width: calc(var(--progress-width, 0) * 1.2rpx);
  max-width: 120rpx;
}

.progress-fill.protein-fill {
  background: #FF6B6B;
}

.progress-fill.fat-fill {
  background: #4ECDC4;
}

.progress-fill.carb-fill {
  background: #96CEB4;
}

.calories-info {
  text-align: center;
  padding: 25rpx;
  background: #f8f9fa;
  border-radius: 15rpx;
}

.calories-value {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #4CAF50;
  margin-bottom: 8rpx;
}

.calories-label {
  display: block;
  font-size: 24rpx;
  color: #666;
}

/* 餐次记录 */
.meals-section {
  background: white;
  border-radius: 25rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 8rpx 30rpx rgba(0,0,0,0.08);
}

.meals-list {
  display: flex;
  flex-direction: column;
  gap: 25rpx;
}

.meal-item {
  background: #f8f9fa;
  border-radius: 15rpx;
  padding: 25rpx;
  border-left: 6rpx solid #4CAF50;
}

.meal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 15rpx;
  border-bottom: 1rpx solid #e0e0e0;
}

.meal-type-time {
  display: flex;
  align-items: center;
  gap: 15rpx;
}

.meal-type {
  font-size: 26rpx;
  font-weight: 600;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
}

.meal-type.breakfast {
  background: rgba(255, 193, 7, 0.1);
  color: #FFA000;
}

.meal-type.lunch {
  background: rgba(76, 175, 80, 0.1);
  color: #4CAF50;
}

.meal-type.dinner {
  background: rgba(33, 150, 243, 0.1);
  color: #2196F3;
}

.meal-type.snack {
  background: rgba(156, 39, 176, 0.1);
  color: #9C27B0;
}

.meal-time {
  font-size: 24rpx;
  color: #999;
}

.meal-calories {
  font-size: 26rpx;
  font-weight: 500;
  color: #4CAF50;
}

.foods-list {
  margin-bottom: 20rpx;
}

.food-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.food-item:last-child {
  border-bottom: none;
}

.food-name {
  font-size: 26rpx;
  color: #333;
}

.food-quantity {
  font-size: 24rpx;
  color: #666;
  background: rgba(0,0,0,0.05);
  padding: 6rpx 12rpx;
  border-radius: 12rpx;
}

.meal-nutrients {
  display: flex;
  gap: 20rpx;
  margin-bottom: 20rpx;
  padding: 15rpx;
  background: white;
  border-radius: 12rpx;
}

.nutrient-detail {
  flex: 1;
  text-align: center;
}

.nutrient-name {
  display: block;
  font-size: 22rpx;
  color: #666;
  margin-bottom: 5rpx;
}

.nutrient-value {
  display: block;
  font-size: 24rpx;
  font-weight: 500;
  color: #2c3e50;
}

.meal-score {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 15rpx;
  border-top: 1rpx solid #e0e0e0;
}

.score-label {
  font-size: 24rpx;
  color: #666;
}

.score-value {
  font-size: 26rpx;
  font-weight: bold;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  background: rgba(76, 175, 80, 0.1);
}

.score-value.excellent {
  color: #4CAF50;
  background: rgba(76, 175, 80, 0.1);
}

.score-value.good {
  color: #FFA000;
  background: rgba(255, 160, 0, 0.1);
}

.score-value.average {
  color: #FF9800;
  background: rgba(255, 152, 0, 0.1);
}

.score-value.poor {
  color: #F44336;
  background: rgba(244, 67, 54, 0.1);
}

/* 健康建议 */
.advice-section {
  background: linear-gradient(135deg, #E3F2FD, #BBDEFB);
  border-radius: 25rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  border-left: 6rpx solid #2196F3;
}

.advice-content {
  margin-top: 15rpx;
}

.advice-text {
  font-size: 26rpx;
  color: #333;
  line-height: 1.6;
  display: block;
}

/* 圆形进度条动画 */
.circle-outer {
  transition: background 0.5s ease;
}

/* 进度条动画 */
.progress-fill {
  transition: width 0.5s ease;
}

/* 响应式设计 */
@media (max-width: 375px) {
  .container {
    padding: 15rpx;
  }
  
  .header {
    flex-direction: column;
    text-align: center;
    gap: 20rpx;
  }
  
  .date-info {
    text-align: center;
  }
  
  .nutrition-card {
    flex-direction: column;
    text-align: center;
    gap: 15rpx;
  }
  
  .nutrient-progress {
    text-align: center;
  }
  
  .meal-header {
    flex-direction: column;
    gap: 10rpx;
    text-align: center;
  }
  
  .meal-type-time {
    justify-content: center;
  }
}

/* 空状态样式 */
.empty-state {
  text-align: center;
  padding: 80rpx 30rpx;
  color: #999;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
  display: block;
}

.empty-text {
  display: block;
  font-size: 28rpx;
  margin-bottom: 10rpx;
}

.empty-desc {
  display: block;
  font-size: 24rpx;
  opacity: 0.7;
}

/* 加载状态 */
.loading {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 60rpx;
}

.loading-text {
  font-size: 28rpx;
  color: #666;
}