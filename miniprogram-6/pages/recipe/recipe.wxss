/* pages/recipe/recipe.wxss */
.container {
  padding: 20rpx;
  background: #f5f5f5;
  min-height: 100vh;
  box-sizing: border-box;
}

.page-header {
  margin-bottom: 30rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.page-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.recipe-count {
  font-size: 24rpx;
  color: #999;
}

/* 加载状态 */
.loading-state {
  text-align: center;
  padding: 100rpx;
  color: #999;
}

.loading-text {
  font-size: 28rpx;
}

/* 食谱列表 */
.recipe-list {
  margin-bottom: 30rpx;
}

.recipe-item {
  background: white;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.08);
}

/* 食谱头部 */
.recipe-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 25rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.recipe-title-section {
  flex: 1;
}

.recipe-name {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
  line-height: 1.4;
}

.recipe-type {
  display: inline-block;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 500;
  margin-right: 10rpx;
}

.recipe-type.breakfast {
  background: #fff0e6;
  color: #ff6b35;
}

.recipe-type.lunch {
  background: #e6f7ff;
  color: #1890ff;
}

.recipe-type.dinner {
  background: #f6ffed;
  color: #52c41a;
}

.recipe-type.snack {
  background: #f9f0ff;
  color: #722ed1;
}

.recipe-time {
  font-size: 22rpx;
  color: #999;
  white-space: nowrap;
}

/* 食物列表 */
.foods-section {
  margin-bottom: 25rpx;
}

.section-title {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
  padding-left: 10rpx;
  border-left: 4rpx solid #00be9a;
}

.foods-list {
  background: #fafafa;
  border-radius: 12rpx;
  padding: 20rpx;
}

.food-item {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.food-item:last-child {
  border-bottom: none;
}

.food-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.food-name {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  flex: 1;
}

.food-amount {
  font-size: 26rpx;
  color: #666;
  font-weight: 500;
  min-width: 100rpx;
  text-align: right;
}

.food-nutrition {
  display: flex;
  gap: 20rpx;
  flex-wrap: wrap;
}

.nutrition-item {
  font-size: 22rpx;
  color: #666;
  background: rgba(0, 190, 154, 0.1);
  padding: 6rpx 12rpx;
  border-radius: 8rpx;
}

.empty-foods {
  text-align: center;
  padding: 40rpx;
  color: #999;
}

.empty-text {
  font-size: 24rpx;
}

/* 营养汇总 */
.nutrition-summary {
  margin-bottom: 25rpx;
}

.summary-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

.summary-item {
  background: #f8f9fa;
  border-radius: 12rpx;
  padding: 20rpx;
  text-align: center;
}

.summary-label {
  display: block;
  font-size: 22rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.summary-value {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: #333;
}

.summary-value.calories {
  color: #ff6b35;
}

/* 操作按钮 */
.recipe-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 20rpx;
}

.btn {
  flex: 1;
  padding: 22rpx;
  border: none;
  border-radius: 12rpx;
  font-size: 26rpx;
  font-weight: 500;
  text-align: center;
}

.btn-use {
  background: #00be9a;
  color: white;
}

.btn-delete {
  background: #f8f8f8;
  color: #ff4757;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 80rpx 30rpx;
  color: #666;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
  display: block;
}

.empty-text {
  display: block;
  font-size: 28rpx;
  margin-bottom: 10rpx;
  font-weight: 500;
}

.empty-desc {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-bottom: 30rpx;
}

.btn-add-recipe {
  display: inline-block;
  padding: 20rpx 40rpx;
  background: #00be9a;
  color: white;
  border-radius: 12rpx;
  font-size: 26rpx;
  font-weight: 500;
}

/* 响应式设计 */
@media (max-width: 375px) {
  .container {
    padding: 15rpx;
  }
  
  .recipe-item {
    padding: 25rpx;
  }
  
  .summary-grid {
    grid-template-columns: repeat(2, 1fr);
  }
  
  .food-nutrition {
    flex-direction: column;
    gap: 10rpx;
  }
}