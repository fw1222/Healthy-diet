/* pages/record/record.wxss */
.record-page {
  padding: 20rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

.page-header {
  margin-bottom: 40rpx;
}

.page-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

/* 表单区域 */
.record-form {
  background: white;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.1);
}

.form-section {
  margin-bottom: 40rpx;
}

.form-section:last-child {
  margin-bottom: 0;
}

.section-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
}

.section-subtitle {
  display: block;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 20rpx;
}

/* 时段选择 */
.meal-type-selector {
  display: flex;
  gap: 20rpx;
}

.meal-type-item {
  flex: 1;
  padding: 20rpx;
  text-align: center;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  background: white;
  transition: all 0.3s;
}

.meal-type-item.active {
  border-color: #00be9a;
  background: #f0fffc;
}

.meal-type-text {
  font-size: 26rpx;
  color: #666;
}

.meal-type-item.active .meal-type-text {
  color: #00be9a;
  font-weight: 600;
}

/* 搜索框 */
.search-box {
  position: relative;
  margin-bottom: 20rpx;
}

.search-input {
  width: 100%;
  padding: 24rpx 60rpx 24rpx 24rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  font-size: 28rpx;
  background: white;
  box-sizing: border-box;
}

.search-icon {
  position: absolute;
  right: 20rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 28rpx;
  color: #999;
}

/* 搜索结果 */
.search-results {
  max-height: 400rpx;
  overflow-y: auto;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  background: white;
}

.search-result-item {
  padding: 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.search-result-item:last-child {
  border-bottom: none;
}

.food-name {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 8rpx;
}

.food-nutrition {
  font-size: 24rpx;
  color: #666;
}

/* 已选食物 */
.selected-food-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
}

.selected-food-item:last-child {
  margin-bottom: 0;
}

.food-info {
  flex: 1;
}

.food-details {
  font-size: 24rpx;
  color: #666;
  margin-top: 8rpx;
}

.food-quantity {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.quantity-input {
  width: 120rpx;
  padding: 12rpx;
  border: 1rpx solid #ddd;
  border-radius: 8rpx;
  text-align: center;
  font-size: 26rpx;
}

.unit {
  font-size: 24rpx;
  color: #666;
}

.remove-btn {
  width: 40rpx;
  height: 40rpx;
  line-height: 36rpx;
  text-align: center;
  border-radius: 50%;
  background: #ff4757;
  color: white;
  font-size: 24rpx;
}

/* 快速食物 */
.quick-foods {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.quick-food-item {
  padding: 16rpx 24rpx;
  background: #f0f0f0;
  border-radius: 20rpx;
  border: 2rpx solid #e0e0e0;
}

.quick-food-name {
  font-size: 26rpx;
  color: #333;
}

/* 食谱功能样式 */
.recipe-section {
  background: #f8f9fa;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 30rpx;
}

.recipe-options {
  display: flex;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.recipe-option {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  background: white;
  border-radius: 10rpx;
  border: 2rpx solid #e0e0e0;
}

.recipe-checkbox {
  width: 32rpx;
  height: 32rpx;
  border: 2rpx solid #ccc;
  border-radius: 6rpx;
  margin-right: 12rpx;
  text-align: center;
  line-height: 28rpx;
  font-size: 20rpx;
  color: white;
}

.recipe-checkbox.checked {
  background: #00be9a;
  border-color: #00be9a;
}

.recipe-label {
  font-size: 26rpx;
  color: #333;
}

.recipe-icon {
  margin-right: 12rpx;
  font-size: 28rpx;
}

.recipe-name-input {
  margin-top: 20rpx;
}

.recipe-input {
  width: 100%;
  padding: 20rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 10rpx;
  background: white;
  font-size: 26rpx;
}

/* 食谱弹窗 */
.recipe-modal {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.recipe-modal-content {
  width: 80%;
  max-height: 70%;
  background: white;
  border-radius: 20rpx;
  overflow: hidden;
}

.recipe-modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.modal-close {
  font-size: 40rpx;
  color: #999;
}

.recipe-list {
  max-height: 500rpx;
  overflow-y: auto;
  padding: 20rpx;
}

.recipe-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.recipe-item:last-child {
  border-bottom: none;
}

.recipe-info {
  flex: 1;
}

.recipe-name {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 8rpx;
}

.recipe-details {
  font-size: 22rpx;
  color: #666;
}

.recipe-arrow {
  font-size: 32rpx;
  color: #999;
}

.empty-recipes {
  text-align: center;
  padding: 60rpx;
  color: #999;
}

/* 营养汇总 */
.nutrition-summary {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
}

.nutrition-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
}

.nutrition-label {
  font-size: 26rpx;
  color: #666;
}

.nutrition-value {
  font-size: 26rpx;
  font-weight: 600;
  color: #333;
}

/* 操作按钮 */
.action-buttons {
  display: flex;
  gap: 20rpx;
  margin-bottom: 40rpx;
}

.btn {
  flex: 1;
  padding: 24rpx;
  border: none;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.btn-cancel {
  background: #f8f8f8;
  color: #666;
}

.btn-save {
  background: #00be9a;
  color: white;
}

.btn-save.disabled {
  background: #ccc;
  color: #999;
}

/* 今日记录 */
/* 优化今日记录样式 */
.today-records-section {
  background: white;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-top: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.1);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.record-count {
  font-size: 24rpx;
  color: #999;
}

.record-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

/* .record-item:last-child {
  border-bottom: none;
} */

.record-main {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

/* 时段标签样式 */
.meal-type-tag {
  padding: 8rpx 16rpx ;
  /* line-height:22rpx; */
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 500;
  min-width: 80rpx;
  text-align: center;
}

.meal-type-tag.breakfast {
  background: #fff0e6;
  color: #ff6b35;
}

.meal-type-tag.lunch {
  background: #e6f7ff;
  color: #1890ff;
}

.meal-type-tag.dinner {
  background: #f6ffed;
  color: #52c41a;
}

.meal-type-tag.snack {
  background: #f9f0ff;
  color: #722ed1;
}

.food-info {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.food-name {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.food-quantity {
  font-size: 22rpx;
  color: #666;
  background: #f5f5f5;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
}

.record-time {
  font-size: 24rpx;
  color: #999;
  min-width: 80rpx;
  text-align: right;
}

.record-details {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.total-calories {
  font-size: 26rpx;
  color: #ff6b35;
  font-weight: 600;
  min-width: 80rpx;
  text-align: right;
}

.remove-record {
  font-size: 24rpx;
  color: #ff4757;
  padding: 8rpx 16rpx;
  border-radius: 6rpx;
  background: #fff0f0;
}

.empty-state {
  text-align: center;
  padding: 60rpx 0;
}

.empty-text {
  display: block;
  font-size: 26rpx;
  color: #999;
  margin-bottom: 16rpx;
}

.empty-hint {
  display: block;
  font-size: 24rpx;
  color: #ccc;
}

/* 拍照按钮样式 */
.camera-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: white;
  padding: 28rpx;
  border-radius: 60rpx;
  font-size: 30rpx;
  font-weight: 500;
  margin-bottom: 16rpx;
}

.camera-icon {
  font-size: 40rpx;
}

.camera-tip {
  font-size: 24rpx;
  color: #999;
  display: block;
  text-align: center;
}

/* 识别结果确认弹窗 */
.recognize-modal {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: flex-end;
  z-index: 1000;
}

.recognize-modal-content {
  background: white;
  border-radius: 40rpx 40rpx 0 0;
  width: 100%;
  max-height: 80vh;
  overflow-y: auto;
  padding: 40rpx;
  animation: slideUp 0.3s ease;
}

@keyframes slideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

.recognize-modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.recognize-modal-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
}

.recognize-modal-close {
  font-size: 48rpx;
  color: #999;
  padding: 10rpx;
}

.recognize-image {
  width: 100%;
  border-radius: 20rpx;
  margin-bottom: 30rpx;
}

.recognize-result-item {
  background: #f8f9fa;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  border: 2rpx solid transparent;
}

.recognize-result-item.selected {
  border-color: #00be9a;
  background: #f0fffc;
}

.recognize-result-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 12rpx;
}

.recognize-result-conf {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 20rpx;
}

.recognize-result-actions {
  display: flex;
  gap: 20rpx;
}

.recognize-result-actions .btn {
  flex: 1;
  padding: 16rpx;
  font-size: 26rpx;
  border-radius: 40rpx;
}

.btn-confirm {
  background: #00be9a;
  color: white;
}

.btn-edit {
  background: #f0f0f0;
  color: #666;
}

.recognize-modal-footer {
  display: flex;
  gap: 20rpx;
  margin-top: 30rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
}

.recognize-modal-footer .btn {
  flex: 1;
  padding: 28rpx;
  border-radius: 60rpx;
  font-size: 30rpx;
}