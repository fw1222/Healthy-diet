<!-- pages/my/my.wxml -->
<view class="container">
  <!-- 用户信息头部 -->
  <view class="user-header">
    <view class="user-avatar">
      <image src="{{userInfo.avatarUrl || '/images/default-avatar.png'}}" class="avatar"></image>
    </view>
    <view class="user-info">
      <text class="user-name">{{hasUserInfo ? (userInfo.nickName || '微信用户') : '未登录'}}</text>
      <text class="user-desc">健康生活，从记录开始</text>
    </view>
    <view class="login-wrap" wx:if="{{!hasUserInfo}}">
      <button class="btn-login" size="mini" bindtap="goToLogin">微信登录</button>
    </view>
    <view class="health-stats">
      <view class="stat-item">
        <text class="stat-value">{{currentBMI || '--'}}</text>
        <text class="stat-label">当前BMI</text>
      </view>
      <view class="stat-item">
        <text class="stat-value">{{continuousDays || 0}}</text>
        <text class="stat-label">连续记录</text>
      </view>
    </view>
  </view>

  <!-- 功能菜单 -->
  <view class="menu-section">
    <view class="menu-title">数据记录</view>
    <view class="menu-grid">
      <view class="menu-item" bindtap="navigateToHistory">
        <view class="menu-icon">📊</view>
        <text class="menu-text">历史膳食记录</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item" bindtap="navigateToHealthJourney">
        <view class="menu-icon">📈</view>
        <text class="menu-text">我的健康之旅</text>
        <text class="menu-arrow">›</text>
      </view>
    </view>
  </view>

  <!-- 历史膳食记录页面 -->
  <view class="page-section" wx:if="{{currentPage === 'history'}}">
    <view class="page-header">
      <view class="back-btn" bindtap="switchPage" data-page="main">‹ 返回</view>
      <text class="page-title">历史膳食记录</text>
    </view>

    <!-- 日期选择器 -->
    <view class="date-filter">
      <picker mode="date" value="{{selectedDate}}" fields="month" bindchange="onDateChange">
        <view class="date-picker">
          <text class="date-text">{{selectedDate}}月记录</text>
          <text class="date-icon">📅</text>
        </view>
      </picker>
    </view>


    <!-- 历史记录列表 -->
    <view class="history-list">
      <view class="history-item" wx:for="{{historyRecords}}" wx:key="date">
        <view class="history-date">
          <text class="date-day">{{item.day}}</text>
          <text class="date-week">{{item.week}}</text>
        </view>
        <view class="history-content">
          <view class="daily-score">
            <text class="score-label">综合评分</text>
            <text class="score-value {{getScoreClass(item.score)}}">{{item.score}}分</text>
          </view>
          <view class="meal-summary">
            <text class="meal-count">{{item.mealCount}}餐记录</text>
            <text class="total-calories">{{item.totalCalories}} kcal</text>
          </view>
          <!-- 显示营养信息 -->
          <view class="nutrition-summary" wx:if="{{item.protein && item.fat && item.carbs}}">
            <text class="nutrition-item">蛋白质: {{item.protein}}g</text>
            <text class="nutrition-item">脂肪: {{item.fat}}g</text>
            <text class="nutrition-item">碳水: {{item.carbs}}g</text>
          </view>
        </view>
        <view class="history-detail" bindtap="viewDayDetail" data-date="{{item.date}}">
          <text class="detail-text">查看详情</text>
          <text class="detail-arrow">›</text>
        </view>
      </view>

      <!-- 空状态 -->
      <view class="empty-state" wx:if="{{historyRecords.length === 0 && loadingComplete}}">
        <text class="empty-icon">📝</text>
        <text class="empty-text">暂无历史记录</text>
        <text class="empty-desc">开始记录您的膳食吧</text>
      </view>
    </view>
  </view>

  <!-- 健康之旅页面 -->
  <view class="page-section"  wx:if="{{currentPage === 'healthJourney'}}">
    <view class="page-header">
      <view class="back-btn" bindtap="switchPage" data-page="main">‹ 返回</view>
      <text class="page-title">我的健康之旅</text>
    </view>

    <!-- 时间范围选择 -->
    <view class="time-range">
      <view class="range-buttons">
        <view 
          class="range-btn {{chartRange === 'month' ? 'active' : ''}}" 
          bindtap="changeChartRange" 
          data-range="month"
        >
          月度视图
        </view>
        <view 
          class="range-btn {{chartRange === 'year' ? 'active' : ''}}" 
          bindtap="changeChartRange" 
          data-range="year"
        >
          年度视图
        </view>
      </view>
    </view>

    <!-- 图表切换 -->
    <view class="chart-tabs">
      <view 
        class="chart-tab {{currentChart === 'diet' ? 'active' : ''}}" 
        bindtap="switchChart" 
        data-chart="diet"
      >
        膳食评分
      </view>
      <view 
        class="chart-tab {{currentChart === 'bmi' ? 'active' : ''}}" 
        bindtap="switchChart" 
        data-chart="bmi"
      >
        BMI趋势
      </view>
    </view>

    <!-- 膳食评分图表 -->
    <view class="chart-container" wx:if="{{currentChart === 'diet'}}">
      <view class="chart-title">膳食评分趋势 ({{chartRange === 'month' ? '近30天' : '近12个月'}})</view>
      <view class="chart-wrapper">
        <canvas 
          canvas-id="dietChart" 
          class="chart-canvas"
          disable-scroll="true"
        ></canvas>
      </view>
      <view class="chart-stats">
        <view class="chart-stat">
          <text class="stat-label">平均评分</text>
          <text class="stat-value">{{dietStats.avgScore || 0}}</text>
        </view>
        <view class="chart-stat">
          <text class="stat-label">最高评分</text>
          <text class="stat-value">{{dietStats.maxScore || 0}}</text>
        </view>
        <view class="chart-stat">
          <text class="stat-label">进步趋势</text>
          <text class="stat-value {{dietStats.trend > 0 ? 'positive' : dietStats.trend < 0 ? 'negative' : ''}}">
            {{dietStats.trend > 0 ? '↑' : dietStats.trend < 0 ? '↓' : '→'}} {{Math.abs(dietStats.trend || 0)}}
          </text>
        </view>
      </view>
    </view>

    <!-- BMI图表 -->
    <view class="chart-container" wx:if="{{currentChart === 'bmi'}}">
      <view class="chart-title">BMI趋势 ({{chartRange === 'month' ? '近30天' : '近12个月'}})</view>
      <view class="chart-wrapper">
        <canvas 
          canvas-id="bmiChart" 
          class="chart-canvas"
          disable-scroll="true"
        ></canvas>
      </view>
      
      <!-- BMI标准参考 -->
      <view class="bmi-standard">
        <view class="standard-title">BMI标准参考</view>
        <view class="standard-list">
          <view class="standard-item underweight">
            <text class="standard-range">＜18.5</text>
            <text class="standard-label">偏瘦</text>
          </view>
          <view class="standard-item normal">
            <text class="standard-range">18.5-23.9</text>
            <text class="standard-label">正常</text>
          </view>
          <view class="standard-item overweight">
            <text class="standard-range">24-27.9</text>
            <text class="standard-label">超重</text>
          </view>
          <view class="standard-item obese">
            <text class="standard-range">≥28</text>
            <text class="standard-label">肥胖</text>
          </view>
        </view>
      </view>

      <view class="chart-stats">
        <view class="chart-stat">
          <text class="stat-label">当前BMI</text>
          <text class="stat-value">{{bmiStats.currentBMI || '--'}}</text>
        </view>
        <view class="chart-stat">
          <text class="stat-label">BMI状态</text>
          <text class="stat-value {{getBMIStatusClass(bmiStats.currentBMI)}}">
            {{getBMIStatus(bmiStats.currentBMI)}}
          </text>
        </view>
        <view class="chart-stat">
          <text class="stat-label">变化趋势</text>
          <text class="stat-value {{bmiStats.trend < 0 ? 'positive' : bmiStats.trend > 0 ? 'negative' : ''}}">
            {{bmiStats.trend < 0 ? '↓' : bmiStats.trend > 0 ? '↑' : '→'}} {{Math.abs(bmiStats.trend || 0)}}
          </text>
        </view>
      </view>
    </view>

    <!-- 健康建议 -->
    <view class="health-advice" wx:if="{{healthAdvice}}">
      <view class="advice-title">💡 健康建议</view>
      <view class="advice-content">{{healthAdvice}}</view>
    </view>
    
  </view>
  <view class="menu-item" bindtap="navigateToRecipe">
  <view class="menu-icon">📚</view>
  <text class="menu-text">我的食谱</text>
  <text class="menu-arrow">›</text>
</view>
</view>

