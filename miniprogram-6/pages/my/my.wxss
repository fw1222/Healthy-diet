/* pages/profile/profile.wxss */

.container {
  padding: 20rpx;
  background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
  min-height: 100vh;
  box-sizing: border-box;
}

/* 用户头部 */
.user-header {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 25rpx;
  padding: 40rpx 30rpx;
  margin-bottom: 30rpx;
  color: white;
  display: flex;
  align-items: center;
  box-shadow: 0 10rpx 30rpx rgba(102, 126, 234, 0.3);
}

.user-avatar {
  margin-right: 25rpx;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255,255,255,0.3);
  background: rgba(255,255,255,0.2); /* 添加背景色避免图片加载失败显示空白 */
}

.user-info {
  flex: 1;
}

.login-wrap {
  margin-left: 16rpx;
}

.btn-login {
  background: rgba(255, 255, 255, 0.95) !important;
  color: #764ba2 !important;
  font-size: 24rpx;
  line-height: 1.6;
}

.user-name {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
  text-shadow: 0 2rpx 4rpx rgba(0,0,0,0.2);
}

.user-desc {
  display: block;
  font-size: 24rpx;
  opacity: 0.9;
  font-weight: 300;
}

.health-stats {
  display: flex;
  gap: 30rpx;
}

.stat-item {
  text-align: center;
}

.stat-value {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 5rpx;
}

.stat-label {
  display: block;
  font-size: 22rpx;
  opacity: 0.8;
}

/* 菜单区域 */
.menu-section {
  background: white;
  border-radius: 25rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 8rpx 30rpx rgba(0,0,0,0.08);
}

.menu-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #2c3e50;
  margin-bottom: 25rpx;
  padding-left: 15rpx;
  border-left: 6rpx solid #4CAF50;
}

.menu-grid {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 30rpx 25rpx;
  background: #f8f9fa;
  border-radius: 15rpx;
  transition: all 0.3s ease;
  border: 2rpx solid transparent;
}

.menu-item:active {
  background: #e9ecef;
  transform: scale(0.98);
  border-color: #4CAF50;
}

.menu-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
  width: 60rpx;
  text-align: center;
}

.menu-text {
  flex: 1;
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
}

.menu-arrow {
  font-size: 36rpx;
  color: #999;
  font-weight: bold;
}

/* 页面区域 */
.page-section {
  background: white;
  border-radius: 25rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 8rpx 30rpx rgba(0,0,0,0.08);
}

.page-header {
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.back-btn {
  font-size: 28rpx;
  color: #4CAF50;
  padding: 15rpx 20rpx;
  margin-right: 20rpx;
  background: rgba(76, 175, 80, 0.1);
  border-radius: 12rpx;
}

.page-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #2c3e50;
}

/* 日期筛选 */
.date-filter {
  margin-bottom: 30rpx;
}

.date-picker {
  background: #f8f9fa;
  border: 2rpx solid #e0e0e0;
  border-radius: 15rpx;
  padding: 25rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 28rpx;
  color: #333;
}

.date-text {
  font-weight: 500;
}

.date-icon {
  font-size: 32rpx;
}

/* 历史记录列表 */
.history-list {
  max-height: 70vh;
  overflow-y: auto;
}

.history-item {
  display: flex;
  align-items: center;
  padding: 25rpx;
  background: #f8f9fa;
  border-radius: 15rpx;
  margin-bottom: 20rpx;
  border-left: 6rpx solid #4CAF50;
}

.history-date {
  text-align: center;
  margin-right: 25rpx;
  min-width: 120rpx;
}

.date-day {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #4CAF50;
  margin-bottom: 5rpx;
}

.date-week {
  display: block;
  font-size: 22rpx;
  color: #666;
}

.history-content {
  flex: 1;
}

.daily-score {
  display: flex;
  align-items: center;
  margin-bottom: 10rpx;
}

.score-label {
  font-size: 26rpx;
  color: #666;
  margin-right: 15rpx;
}

.score-value {
  font-size: 28rpx;
  font-weight: bold;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  background: rgba(76, 175, 80, 0.1);
}

.score-value.excellent { color: #4CAF50; background: rgba(76, 175, 80, 0.1); }
.score-value.good { color: #FFA000; background: rgba(255, 160, 0, 0.1); }
.score-value.average { color: #FF9800; background: rgba(255, 152, 0, 0.1); }
.score-value.poor { color: #F44336; background: rgba(244, 67, 54, 0.1); }

.meal-summary {
  display: flex;
  gap: 20rpx;
}

.meal-count, .total-calories {
  font-size: 24rpx;
  color: #999;
}

.history-detail {
  display: flex;
  align-items: center;
  padding: 15rpx 20rpx;
  background: rgba(76, 175, 80, 0.1);
  border-radius: 12rpx;
}

.detail-text {
  font-size: 24rpx;
  color: #4CAF50;
  margin-right: 10rpx;
}

.detail-arrow {
  font-size: 28rpx;
  color: #4CAF50;
  font-weight: bold;
}

/* 时间范围选择 */
.time-range {
  margin-bottom: 30rpx;
}

.range-buttons {
  display: flex;
  background: #f8f9fa;
  border-radius: 15rpx;
  padding: 8rpx;
}

.range-btn {
  flex: 1;
  text-align: center;
  padding: 20rpx;
  font-size: 26rpx;
  color: #666;
  border-radius: 12rpx;
  transition: all 0.3s ease;
}

.range-btn.active {
  background: white;
  color: #4CAF50;
  font-weight: 500;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.1);
}

/* 图表标签 */
.chart-tabs {
  display: flex;
  background: #f8f9fa;
  border-radius: 15rpx;
  padding: 8rpx;
  margin-bottom: 30rpx;
}

.chart-tab {
  flex: 1;
  text-align: center;
  padding: 20rpx;
  font-size: 26rpx;
  color: #666;
  border-radius: 12rpx;
  transition: all 0.3s ease;
}

.chart-tab.active {
  background: white;
  color: #4CAF50;
  font-weight: 500;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.1);
}

/* 图表容器 - 修复尺寸 */
.chart-container {
  margin-bottom: 30rpx;
}

.chart-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #2c3e50;
  margin-bottom: 20rpx;
  text-align: center;
}

.chart-wrapper {
  background: #f8f9fa;
  border-radius: 15rpx;
  padding: 25rpx;
  margin-bottom: 25rpx;
  height: 350rpx; /* 固定高度，比之前小 */
  position: relative;
  overflow: hidden;
}

.chart-canvas {
  width: 100%;
  height: 100%;
  display: block;
}

/* 图表统计 */
.chart-stats {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
}

.chart-stat {
  flex: 1;
  text-align: center;
  background: #f8f9fa;
  padding: 25rpx 15rpx;
  border-radius: 12rpx;
}

.stat-label {
  display: block;
  font-size: 24rpx;
  color: #666;
  margin-bottom: 10rpx;
}

.stat-value {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: #4CAF50;
}

.stat-value.positive { color: #4CAF50; }
.stat-value.negative { color: #F44336; }

/* BMI标准 */
.bmi-standard {
  background: #f8f9fa;
  border-radius: 15rpx;
  padding: 25rpx;
  margin-bottom: 25rpx;
}

.standard-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
  text-align: center;
}

.standard-list {
  display: flex;
  justify-content: space-between;
  gap: 10rpx;
}

.standard-item {
  flex: 1;
  text-align: center;
  padding: 15rpx 10rpx;
  border-radius: 10rpx;
  font-size: 22rpx;
}

.standard-item.underweight { background: #E3F2FD; color: #1976D2; }
.standard-item.normal { background: #E8F5E8; color: #4CAF50; }
.standard-item.overweight { background: #FFF3E0; color: #FF9800; }
.standard-item.obese { background: #FFEBEE; color: #F44336; }

.standard-range {
  display: block;
  font-weight: 500;
  margin-bottom: 5rpx;
}

.standard-label {
  display: block;
}

/* 健康建议 */
.health-advice {
  background: linear-gradient(135deg, #E3F2FD, #BBDEFB);
  border-radius: 15rpx;
  padding: 30rpx;
  border-left: 6rpx solid #2196F3;
}

.advice-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1976D2;
  margin-bottom: 15rpx;
}

.advice-content {
  font-size: 26rpx;
  color: #333;
  line-height: 1.6;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 80rpx 30rpx;
  color: #999;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
  display: block;
}

.empty-text {
  display: block;
  font-size: 28rpx;
  margin-bottom: 10rpx;
}

.empty-desc {
  display: block;
  font-size: 24rpx;
  opacity: 0.7;
}

/* 响应式设计 */
@media (max-width: 375px) {
  .container {
    padding: 15rpx;
  }
  
  .user-header {
    flex-direction: column;
    text-align: center;
    gap: 20rpx;
  }
  
  .user-avatar {
    margin-right: 0;
  }
  
  .health-stats {
    width: 100%;
    justify-content: space-around;
  }
  
  .history-item {
    flex-direction: column;
    text-align: center;
    gap: 15rpx;
  }
  
  .history-date {
    margin-right: 0;
  }
  
  .history-content {
    width: 100%;
  }
  
  .daily-score {
    justify-content: center;
  }
  
  .meal-summary {
    justify-content: center;
  }
  
  .chart-stats {
    flex-direction: column;
    gap: 15rpx;
  }
  
  .standard-list {
    flex-wrap: wrap;
  }
  
  .standard-item {
    flex: 0 0 calc(50% - 5rpx);
    margin-bottom: 10rpx;
  }
  
  /* 小屏幕图表调整 */
  .chart-wrapper {
    height: 280rpx;
    padding: 20rpx;
  }
}

/* 加载动画 */
@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(30rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.score-card, .quick-actions, .weight-section, .recommendation-section {
  animation: fadeInUp 0.6s ease-out;
}

.quick-actions {
  animation-delay: 0.1s;
}

.weight-section {
  animation-delay: 0.2s;
}

.recommendation-section {
  animation-delay: 0.3s;
}

/* 滚动条样式 */
.history-list::-webkit-scrollbar {
  width: 6rpx;
}

.history-list::-webkit-scrollbar-track {
  background: #f1f1f1;
  border-radius: 3rpx;
}

.history-list::-webkit-scrollbar-thumb {
  background: #c1c1c1;
  border-radius: 3rpx;
}

.history-list::-webkit-scrollbar-thumb:hover {
  background: #a8a8a8;
}

/* 营养信息摘要 */
.nutrition-summary {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 15rpx;
}

.nutrition-item {
  font-size: 22rpx;
  color: #666;
  background: rgba(76, 175, 80, 0.1);
  padding: 6rpx 12rpx;
  border-radius: 12rpx;
}

/* 加载状态 */
.loading-state {
  text-align: center;
  padding: 60rpx;
  color: #999;
}

.loading-text {
  font-size: 28rpx;
}

/* 历史记录内容调整 */
.history-content {
  flex: 1;
  min-width: 0; /* 防止内容溢出 */
}

/* 响应式调整 */
@media (max-width: 375px) {
  .nutrition-summary {
    flex-direction: column;
    gap: 5rpx;
  }
  
  .nutrition-item {
    font-size: 20rpx;
    padding: 4rpx 8rpx;
  }
}