/**index.wxss**/
.tip{
  padding-top: 10rpx;
  padding-bottom: 10rpx;
  background-color: rgb(163, 231, 197);
}

.tip .icon{
  font-size: 35rpx;
}

.menu{
  display: flex;
  justify-content: space-around;
  padding:16rpx;
  border-radius: 10rpx;
  flex-wrap: wrap;
  background-color: azure;
}

.menu .item{
  display: flex;
  /* display: block; */
  flex-direction: column;
  justify-content: center;
  align-items: center;
  width: 180rpx;
  height: 180rpx;
  border: rgb(163, 231, 197) solid 1rpx;
  border-radius: 50rpx;
  font-size: 25rpx;
}

.item .img
{
width: 88rpx;
height: 88rpx;
}

.title{
  margin-top: 20rpx;
  font-weight: 1000;
  font-size: 34rpx;
}

.recipe{
  display: flex;
  justify-content: space-between;
  padding:5rpx;
  justify-content: center;
  align-items: center;
  flex-wrap: wrap;
}

.recipe .item{

border-radius: 20rpx;
width: 350rpx;
height: 400rpx;
border: rgb(163, 231, 197) solid 1rpx;

}

.recipe .img{
  width: 350rpx;
  height: 290rpx;
  border-radius: 10rpx;
  margin-bottom: 10rpx;
}


.more{
  
  display: flex;
  align-items: flex-end;
  justify-content: flex-end;
  color: rgb(132, 135, 138);
}

.more .icon{
  font-size: 30rpx;
}

/* 评分卡片样式 */
.score-card {
  background: white;
  border-radius: 25rpx;
  padding: 40rpx 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 8rpx 30rpx rgba(0,0,0,0.08);
  border: 1rpx solid rgba(255,255,255,0.2);
  backdrop-filter: blur(10rpx);
}

.score-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #2c3e50;
  margin-bottom: 35rpx;
  text-align: center;
  position: relative;
}

.score-title::after {
  content: '';
  position: absolute;
  bottom: -10rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 4rpx;
  background: linear-gradient(135deg, #667eea, #764ba2);
  border-radius: 2rpx;
}

.score-content {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

/* 圆形进度条样式 */
.score-circle {
  position: relative;
  width: 200rpx;
  height: 200rpx;
}

.circle-progress {
  position: relative;
  width: 200rpx;
  height: 200rpx;
}

.circle-outer {
  width: 200rpx;
  height: 200rpx;
  border: 12rpx solid #f0f0f0;
  border-radius: 50%;
  position: relative;
  overflow: hidden;
  background: conic-gradient(
    #4CAF50 0deg, 
    #4CAF50 calc(var(--progress, 0) * 3.6deg), 
    #f0f0f0 calc(var(--progress, 0) * 3.6deg), 
    #f0f0f0 360deg
  );
}

.circle-inner {
  position: absolute;
  top: 12rpx;
  left: 12rpx;
  width: 176rpx;
  height: 176rpx;
  background: white;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.score-text {
  font-size: 48rpx;
  font-weight: bold;
  color: #4CAF50;
  text-shadow: 0 2rpx 4rpx rgba(76, 175, 80, 0.2);
}

.score-label {
  font-size: 24rpx;
  color: #666;
  margin-top: 5rpx;
}

/* 评分详情样式 */
.score-details {
  flex: 1;
  margin-left: 40rpx;
}

.nutrient-score {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
  transition: all 0.3s ease;
}

.nutrient-score:last-child {
  border-bottom: none;
}

.nutrient-score:active {
  background-color: #f8f9fa;
  border-radius: 12rpx;
  transform: scale(0.98);
}

.nutrient-name {
  font-size: 28rpx;
  color: #555;
  font-weight: 500;
}

.score {
  font-size: 28rpx;
  font-weight: bold;
  color: #4CAF50;
  background: rgba(76, 175, 80, 0.1);
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  min-width: 80rpx;
  text-align: center;
}
