/**index.wxss**/

.tip {
  padding: 20rpx;
  background: #e8f5e9;
  font-size: 26rpx;
  color: #666;
  text-align: center;
}

.tip .icon {
  margin-right: 10rpx;
}

/* 评分卡片 */
.score-card {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 32rpx;
  margin: 20rpx;
  padding: 30rpx;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.3);
}

.score-header {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  margin-bottom: 30rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid rgba(255,255,255,0.2);
}

.score-title {
  font-size: 32rpx;
  color: rgba(255,255,255,0.9);
}

.score-value {
  font-size: 56rpx;
  font-weight: bold;
  color: white;
  text-shadow: 0 2rpx 4rpx rgba(0,0,0,0.1);
}

/* 评分项 */
.score-items {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.score-item {
  background: rgba(255,255,255,0.15);
  border-radius: 20rpx;
  padding: 20rpx;
  transition: all 0.2s ease;
}

.score-item:active {
  background: rgba(255,255,255,0.25);
  transform: scale(0.98);
}

.item-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.item-name {
  font-size: 28rpx;
  color: white;
}

.item-score {
  font-size: 28rpx;
  font-weight: bold;
  padding: 4rpx 16rpx;
  border-radius: 30rpx;
}

.item-score.high {
  background: rgba(76, 175, 80, 0.3);
  color: #C8E6C9;
}

.item-score.medium {
  background: rgba(255, 193, 7, 0.3);
  color: #FFECB3;
}

.item-score.low {
  background: rgba(244, 67, 54, 0.3);
  color: #FFCDD2;
}

.progress-bar {
  height: 8rpx;
  background: rgba(255,255,255,0.2);
  border-radius: 4rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  border-radius: 4rpx;
  transition: width 0.3s ease;
}

/* 扣分详情面板 */
.detail-panel {
  background: white;
  border-radius: 20rpx;
  margin-top: 25rpx;
  overflow: hidden;
  animation: slideDown 0.3s ease;
}

@keyframes slideDown {
  from {
    opacity: 0;
    transform: translateY(-10rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.detail-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  background: #f5f5f5;
  padding: 20rpx;
  border-bottom: 1rpx solid #eee;
}

.detail-icon {
  font-size: 36rpx;
}

.detail-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.detail-content {
  padding: 25rpx;
}

.detail-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 15rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
  font-size: 28rpx;
  color: #666;
}

.detail-row:last-child {
  border-bottom: none;
}

.detail-value {
  font-weight: 500;
  color: #333;
}

.detail-reason {
  margin-top: 20rpx;
  padding: 20rpx;
  background: #f8f9fa;
  border-radius: 16rpx;
}

.detail-reason.perfect {
  background: #e8f5e9;
}

.reason-tag {
  display: inline-block;
  font-size: 24rpx;
  padding: 4rpx 12rpx;
  background: #ff9800;
  color: white;
  border-radius: 20rpx;
  margin-bottom: 12rpx;
}

.perfect .reason-tag {
  background: #4CAF50;
}

.reason-text {
  display: block;
  font-size: 26rpx;
  color: #555;
  margin-bottom: 10rpx;
}

.deduction {
  display: inline-block;
  font-size: 26rpx;
  font-weight: bold;
  color: #f44336;
}

/* 快捷入口 */
.menu {
  display: flex;
  justify-content: space-around;
  background: white;
  margin: 20rpx;
  padding: 20rpx;
  border-radius: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}

.menu-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  padding: 20rpx 40rpx;
  border-radius: 20rpx;
  transition: all 0.2s ease;
}

.menu-item:active {
  background: #f5f5f5;
}

.menu-icon {
  width: 80rpx;
  height: 80rpx;
}

.menu-item text {
  font-size: 26rpx;
  color: #666;
}

/* 今日推荐区域 */
.section {
  margin: 20rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  margin-bottom: 20rpx;
  padding: 0 10rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
}

.section-more {
  font-size: 26rpx;
  color: #999;
}

.recipe-list {
  white-space: nowrap;
  display: flex;
}

.recipe-item {
  display: inline-block;
  width: 280rpx;
  margin-right: 20rpx;
  background: white;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.08);
}

.recipe-img {
  width: 280rpx;
  height: 200rpx;
}

.recipe-name {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  padding: 15rpx;
  white-space: normal;
}

.recipe-btn {
  font-size: 24rpx;
  color: #667eea;
  padding: 0 15rpx 15rpx 15rpx;
}